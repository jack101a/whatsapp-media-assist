ENVIRONMENT=production
APP_NAME=Media Assist
API_BASE_URL=https://mediaassist.002529.xyz
FRONTEND_SUCCESS_URL=https://mediaassist.002529.xyz/payment-complete
DATABASE_URL=postgresql+psycopg://mediaassist:CHANGE_DB_PASSWORD@db:5432/mediaassist

JWT_SECRET=CHANGE_TO_64_RANDOM_CHARACTERS
OTP_PEPPER=CHANGE_TO_ANOTHER_64_RANDOM_VALUE
ADMIN_API_KEY=CHANGE_TO_LONG_ADMIN_KEY
ENTITLEMENT_PRIVATE_KEY_PATH=/run/secrets/entitlement_private_key.pem

RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxx
PRICE_INR_MINOR=50000
PRICE_USD_MINOR=499
ENABLE_INR_CHECKOUT=true
# Set true only after Razorpay enables international payments for your account.
ENABLE_USD_CHECKOUT=false
ANNUAL_LICENSE_DAYS=365
OTP_IP_HOURLY_LIMIT=12
OTP_EMAIL_DAILY_LIMIT=12

BREVO_API_KEY=xkeysib-xxxxx
BREVO_SENDER_EMAIL=no-reply@002529.xyz
BREVO_SENDER_NAME=Media Assist
BREVO_SANDBOX=false

MAX_DEVICES=3
ENTITLEMENT_REFRESH_HOURS=24
ENTITLEMENT_GRACE_HOURS=72
ALLOWED_ORIGINS=
